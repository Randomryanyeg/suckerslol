{
  "entities": {
    "User": {
      "title": "User Account",
      "description": "Represents a user in the system with their banking details and settings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "enabled": { "type": "boolean" },
        "isLocked": { "type": "boolean" },
        "isApproved": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" },
        "securityWord": { "type": "string" },
        "scenePoints": { "type": "number" },
        "workplace": { "type": "string" },
        "annualIncome": { "type": "string" },
        "homeAddress": { "type": "string" },
        "accounts": { "type": "object" },
        "contacts": { "type": "array" },
        "purchasedCards": { "type": "array" },
        "settings": { "type": "object" },
        "autoDeleteAt": { "type": "string" }
      },
      "required": ["username", "password"]
    },
    "GlobalSettings": {
      "title": "Global Settings",
      "description": "System-wide configuration for the simulator.",
      "type": "object",
      "properties": {
        "general": { "type": "object" },
        "smtp": { "type": "object" },
        "telegram": { "type": "object" }
      }
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in a support chat.",
      "type": "object",
      "properties": {
        "from": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "number" },
        "to": { "type": "string" }
      },
      "required": ["from", "message", "timestamp"]
    }
  },
  "firestore": {
    "users/{username}": {
      "schema": "User",
      "description": "Collection of users keyed by their unique username."
    },
    "settings/global": {
      "schema": "GlobalSettings",
      "description": "Global singleton configuration document."
    },
    "chats/{userId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Subcollection of chat messages for a specific user."
    }
  }
}
